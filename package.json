{
  "name": "wunderland",
  "version": "0.72.3",
  "description": "Autonomous AI agents you deploy in 30 seconds across any channel. Interactive setup wizard, 37 channel adapters, HEXACO personality and cognitive memory powered by AgentOS, five-tier prompt-injection defense.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./api": {
      "import": "./dist/channels/api/api-index.js",
      "types": "./dist/channels/api/api-index.d.ts"
    },
    "./discovery": {
      "import": "./dist/platform/discovery/discovery-index.js",
      "types": "./dist/platform/discovery/discovery-index.d.ts"
    }
  },
  "files": [
    "dist",
    "bin",
    "presets",
    "assets"
  ],
  "bin": {
    "wunderland": "bin/wunderland.js"
  },
  "scripts": {
    "prepare": "test -d dist || npm run build",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:security": "vitest run --reporter=verbose src/security",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "smoke": "node scripts/smoke.mjs",
    "changelog": "npx conventional-changelog -p conventionalcommits -i CHANGELOG.md -s -r 0",
    "release": "npm run build && npm run changelog && npm publish --access public"
  },
  "keywords": [
    "ai",
    "assistant",
    "agent",
    "agentos",
    "chatbot",
    "telegram",
    "discord",
    "slack",
    "whatsapp",
    "personal-assistant",
    "ai-agent",
    "llm",
    "automation",
    "hexaco",
    "personality",
    "hitl",
    "human-in-the-loop"
  ],
  "author": {
    "name": "Rabbit Hole Inc",
    "email": "hi@rabbithole.inc",
    "url": "https://rabbithole.inc"
  },
  "license": "Apache-2.0",
  "homepage": "https://wunderland.sh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jddunn/wunderland.git"
  },
  "bugs": {
    "url": "https://github.com/jddunn/wunderland/issues"
  },
  "engines": {
    "node": ">=18.0.0 <26.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@framers/agentos": "^0.9.16",
    "@framers/agentos-ext-cli-executor": "^1.2.0",
    "@framers/agentos-ext-giphy": "^1.0.0",
    "@framers/agentos-ext-image-search": "^1.0.0",
    "@framers/agentos-ext-news-search": "^1.0.0",
    "@framers/agentos-ext-voice-synthesis": "^2.0.1",
    "@framers/agentos-ext-web-browser": "^1.2.1",
    "@framers/agentos-ext-web-search": "^1.1.1",
    "@framers/agentos-extensions-registry": "^0.18.2",
    "@framers/sql-storage-adapter": "^0.6.6",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.201.1",
    "@opentelemetry/auto-instrumentations-node": "^0.59.0",
    "@opentelemetry/sdk-node": "^0.201.1",
    "ansi-to-html": "^0.7.2",
    "boxen": "^8.0.1",
    "cfonts": "^3.3.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "gradient-string": "^3.0.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-types": "^0.24.8",
    "hnswlib-node": "^3.0.0",
    "minimatch": "^9.0.3",
    "nanospinner": "^1.2.2",
    "openai": "^4.100.0",
    "playwright-core": "^1.58.1",
    "uuid": "^9.0.0",
    "yaml": "^2.8.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@framers/agentos-ext-code-safety": "^0.2.1",
    "@framers/agentos-ext-grounding-guard": "^0.2.1",
    "@framers/agentos-ext-ml-classifiers": "^0.3.1",
    "@framers/agentos-ext-pii-redaction": "^0.2.1",
    "@framers/agentos-ext-topicality": "^0.2.2"
  },
