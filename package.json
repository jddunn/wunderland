    "@framers/agentos-ext-streaming-tts-openai": "^0.2.0",
    "@framers/agentos-ext-vosk": "^0.2.0",
    "@framers/agentos-skills-registry": "^0.18.3"
  },
  "devDependencies": {
    "@framers/agentos-skills-registry": "^0.18.3",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.0",
    "@vitest/coverage-v8": "^1.3.0",
    "typescript": "^5.4.0",
    "undici": "^7.24.4",
    "vitest": "^1.3.0"
  }
}
