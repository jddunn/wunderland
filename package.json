{
  "name": "wunderland",
  "version": "0.49.0",
  "description": "Autonomous AI agent framework with cognitive memory, infinite-context graph-based RAG, and HEXACO personality modeling — built on OpenClaw with 5-tier prompt-injection defense, adaptive HyDE retrieval, observational memory with Ebbinghaus decay, 37 channel integrations, and a zero-config CLI",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./api": {
      "import": "./dist/api/index.js",
      "types": "./dist/api/index.d.ts"
    },
    "./tools": {
      "import": "./dist/tools/index.js",
      "types": "./dist/tools/index.d.ts"
    },
    "./advanced": {
      "import": "./dist/advanced/index.js",
      "types": "./dist/advanced/index.d.ts"
    },
    "./advanced/*": {
      "import": "./dist/advanced/*.js",
      "types": "./dist/advanced/*.d.ts"
    },
    "./config": {
      "import": "./dist/config/index.js",
      "types": "./dist/config/index.d.ts"
    },
    "./security": {
      "import": "./dist/security/index.js",
      "types": "./dist/security/index.d.ts"
    },
    "./runtime": {
      "import": "./dist/runtime/index.js",
      "types": "./dist/runtime/index.d.ts"
    },
    "./storage": {
      "import": "./dist/storage/index.js",
      "types": "./dist/storage/index.d.ts"
    },
    "./guardrails": {
      "import": "./dist/guardrails/index.js",
      "types": "./dist/guardrails/index.d.ts"
    },
    "./voice": {
      "import": "./dist/voice/index.js",
      "types": "./dist/voice/index.d.ts"
    },
    "./discovery": {
      "import": "./dist/discovery/index.js",
      "types": "./dist/discovery/index.d.ts"
    },
    "./presets": {
      "import": "./dist/core/PresetLoader.js",
      "types": "./dist/core/PresetLoader.d.ts"
    },
    "./presets/agents/*/agent.config.json": {
      "import": "./presets/agents/*/agent.config.json"
    },
    "./presets/*.json": {
      "import": "./presets/*.json"
    }
  },
  "files": [
    "dist",
    "bin",
    "presets",
    "assets"
  ],
  "bin": {
    "wunderland": "bin/wunderland.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:security": "vitest run --reporter=verbose src/security",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "changelog": "npx conventional-changelog -p conventionalcommits -i CHANGELOG.md -s -r 0",
    "release": "npm run build && npm run changelog && npm publish --access public"
  },
  "keywords": [
    "ai",
    "assistant",
    "agent",
    "agentos",
    "chatbot",
    "telegram",
    "discord",
    "slack",
    "whatsapp",
    "personal-assistant",
    "ai-agent",
    "llm",
    "automation",
    "hexaco",
    "personality",
    "hitl",
    "human-in-the-loop"
  ],
  "author": {
    "name": "jdunnfive",
    "url": "https://github.com/jddunn"
  },
  "license": "MIT",
  "homepage": "https://wunderland.sh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jddunn/wunderland.git"
  },
  "bugs": {
    "url": "https://github.com/jddunn/wunderland/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@framers/agentos": ">=0.1.0",
    "@framers/agentos-ext-cli-executor": "^1.2.0",
    "@framers/agentos-ext-giphy": "^1.0.0",
    "@framers/agentos-ext-image-search": "^1.0.0",
    "@framers/agentos-ext-news-search": "^1.0.0",
    "@framers/agentos-ext-voice-synthesis": ">=1.0.0",
    "@framers/agentos-ext-web-browser": "^1.2.1",
    "@framers/agentos-ext-web-search": "^1.1.1",
    "@framers/agentos-extensions-registry": ">=0.1.0",
    "@framers/sql-storage-adapter": "^0.5.3",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.201.1",
    "@opentelemetry/auto-instrumentations-node": "^0.59.0",
    "@opentelemetry/sdk-node": "^0.201.1",
    "ansi-to-html": "^0.7.2",
    "boxen": "^8.0.1",
    "cfonts": "^3.3.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "gradient-string": "^3.0.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-types": "^0.24.8",
    "hnswlib-node": "^3.0.0",
    "minimatch": "^9.0.3",
    "nanospinner": "^1.2.2",
    "playwright-core": "^1.58.1",
    "uuid": "^9.0.0"
  },
  "peerDependencies": {
    "@framers/agentos-ext-pii-redaction": ">=0.1.0",
    "@framers/agentos-ext-ml-classifiers": ">=0.1.0",
    "@framers/agentos-ext-topicality": ">=0.1.0",
    "@framers/agentos-ext-code-safety": ">=0.1.0",
    "@framers/agentos-ext-grounding-guard": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@framers/agentos-ext-pii-redaction": {
      "optional": true
    },
    "@framers/agentos-ext-ml-classifiers": {
      "optional": true
    },
    "@framers/agentos-ext-topicality": {
      "optional": true
    },
    "@framers/agentos-ext-code-safety": {
      "optional": true
    },
    "@framers/agentos-ext-grounding-guard": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@framers/agentos-skills-registry": ">=0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.0",
    "@vitest/coverage-v8": "^1.3.0",
    "typescript": "^5.4.0",
    "undici": "^7.24.4",
    "vitest": "^1.3.0"
  }
}
